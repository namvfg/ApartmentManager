<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ApartmentManager">

        <!-- ── LAUNCHER ── -->
        <activity
            android:name=".presentation.ui.auth.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── AUTH ── -->
        <activity
            android:name=".presentation.ui.auth.login.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.register.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.register.OtpVerifyActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.login.ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.password.OtpResetPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.auth.password.NewPasswordActivity"
            android:exported="false" />

        <!-- ── MAIN ── -->
        <activity
            android:name=".presentation.ui.admin.AdminMainActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.user.UserMainActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="momosuccess"
                    android:scheme="apartmentmanager" />
            </intent-filter>
        </activity>

        <!-- ── ADMIN ── -->
        <activity
            android:name=".presentation.ui.admin.apartment.ApartmentActivity"
            android:exported="true">

        </activity>
        <activity
            android:name=".presentation.ui.admin.CreateContractActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.admin.apartment.BlockUnitActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.admin.apartment.InviteActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.admin.ServiceActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.admin.ContractDetailActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.admin.UpdatePriceElectricActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.admin.UpdatePriceWaterActivity"
            android:exported="false" />

        <!-- ── USER ── -->
        <activity
            android:name=".presentation.ui.user.UserActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.user.UserDetailActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.user.JoinActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.user.DeleteUserActivity"
            android:exported="false" />
        <activity
            android:name=".presentation.ui.user.DeleteConfirmActivity"
            android:exported="false" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />

    </application>

</manifest>