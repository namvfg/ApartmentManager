<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="@color/bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/profile_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_splash_gradient"
                android:padding="26dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tv_profile_avatar"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@color/primary_pale"
                    android:gravity="center"
                    android:text="NA"
                    android:textStyle="bold"
                    android:textColor="@color/primary_dark"
                    android:textSize="22sp"
                    android:layout_marginBottom="10dp"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên người dùng"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_profile_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="Cư dân"
                    android:textColor="@color/primary_dark"
                    android:textStyle="bold"
                    android:background="@color/primary_pale"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="18dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_item_edit_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:weightSum="1">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginLeft="30dp"
                            android:background="@color/primary_pale"
                            android:src="@drawable/ic_auth_user_outline"
                            android:padding="7dp"
                            app:tint="@color/primary_dark" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Thông tin cá nhân"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginRight="20dp"
                            android:src="@drawable/ic_auth_chevron_right"
                            app:tint="@color/text_hint" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_item_change_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginLeft="30dp"

                            android:background="@color/primary_pale"
                            android:src="@drawable/ic_auth_password_outline"
                            android:padding="7dp"
                            app:tint="@color/primary_dark" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Đổi mật khẩu"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_marginRight="20dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_auth_chevron_right"
                            app:tint="@color/text_hint" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_item_notification_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginLeft="30dp"

                            android:background="@color/primary_pale"
                            android:src="@drawable/ic_auth_bell_outline"
                            android:padding="7dp"
                            app:tint="@color/primary_dark" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cài đặt thông báo"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_marginRight="20dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_auth_chevron_right"
                            app:tint="@color/text_hint" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_item_logout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginLeft="30dp"

                            android:background="#FEE2E2"
                            android:src="@drawable/ic_auth_logout_outline"
                            android:padding="7dp"
                            app:tint="@color/error" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Đăng xuất"
                            android:textColor="@color/error"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Button
                    android:id="@+id/btn_request_delete"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Yêu cầu xóa tài khoản"
                    android:textSize="14sp"
                    android:textColor="@color/error"
                    android:backgroundTint="@color/white"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginTop="4dp"
                    android:drawableLeft="@drawable/ic_auth_trash_outline_small"
                    android:drawablePadding="10dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

