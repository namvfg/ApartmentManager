<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_input"
        android:clickable="true"
        android:contentDescription="Back"
        android:focusable="true"
        android:padding="8dp"
        android:elevation="10dp"
        android:src="@drawable/ic_auth_back_chevron"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:tint="@color/primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="100dp"
                android:padding="26dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/tv_otp_icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:padding="18dp"
                    android:src="@drawable/ic_auth_email_outline"
                    android:layout_marginBottom="16dp"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:id="@+id/tv_otp_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xác thực email"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_otp_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã OTP đã được gửi đến"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1.5dp"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_pending_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="18dp">

                        <EditText
                            android:id="@+id/otp_1"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_auth_otp_cell"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1" />
                        <EditText
                            android:id="@+id/otp_2"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_auth_otp_cell"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1" />
                        <EditText
                            android:id="@+id/otp_3"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_auth_otp_cell"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1" />
                        <EditText
                            android:id="@+id/otp_4"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_auth_otp_cell"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1" />
                        <EditText
                            android:id="@+id/otp_5"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_auth_otp_cell"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1" />
                        <EditText
                            android:id="@+id/otp_6"
                            android:layout_width="42dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_auth_otp_cell"
                            android:gravity="center"
                            android:inputType="numberPassword"
                            android:maxLength="1" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_otp_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginLeft="30dp"
                        android:layout_marginRight="30dp"
                        android:text="Xác nhận"
                        android:textSize="16sp"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/tv_resend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Không nhận được mã? Gửi lại"
                        android:textColor="@color/text_secondary"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="14dp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

