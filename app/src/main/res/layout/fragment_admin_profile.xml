<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="20dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/profile_header"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:background="@drawable/bg_splash_gradient"
                android:padding="18dp">

                <View
                    android:id="@+id/header_circle"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:layout_marginTop="-140dp"
                    android:layout_marginEnd="-120dp"
                    android:background="#0D68BA7F"
                    android:alpha="0.65"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <FrameLayout
                    android:id="@+id/admin_icon_wrap"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:background="@drawable/bg_splash_icon_container"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tv_profile_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_auth_new_password_shield"
                        android:tint="#CFFFDC" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Super Admin"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    app:layout_constraintTop_toBottomOf="@id/admin_icon_wrap"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[email protected]"
                    android:textColor="@color/th"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_profile_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_profile_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="ADMIN"
                    android:textColor="@color/pd"
                    android:textStyle="bold"
                    android:background="@color/pp"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_profile_email"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HỆ THỐNG"
                    android:textColor="@color/th"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/div"
                    app:strokeWidth="1dp"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/row_manage_apartment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="#E6F7EC"
                                android:src="@drawable/ic_auth_house"
                                android:tint="@color/p"
                                android:padding="10dp"
                                android:layout_marginStart="6dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Quản lý chung cư"
                                    android:textColor="@color/t1"
                                    android:textStyle="bold"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/tv_apartment_sub"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="12 chung cư đang hoạt động"
                                    android:textColor="@color/th"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_auth_chevron_right"
                                android:tint="@color/th"
                                android:layout_marginEnd="10dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/div"
                            android:layout_marginStart="60dp"
                            android:layout_marginEnd="6dp" />

                        <LinearLayout
                            android:id="@+id/row_manage_admin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="#E6F7EC"
                                android:src="@drawable/ic_auth_user_outline"
                                android:tint="@color/p"
                                android:padding="10dp"
                                android:layout_marginStart="6dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Quản lý Admin"
                                    android:textColor="@color/t1"
                                    android:textStyle="bold"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/tv_admin_sub"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="8 tài khoản Admin"
                                    android:textColor="@color/th"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_auth_chevron_right"
                                android:tint="@color/th"
                                android:layout_marginEnd="10dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/div"
                            android:layout_marginStart="60dp"
                            android:layout_marginEnd="6dp" />

                        <LinearLayout
                            android:id="@+id/row_report"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="#E6F7EC"
                                android:src="@drawable/ic_admin_chart_outline"
                                android:tint="@color/p"
                                android:padding="10dp"
                                android:layout_marginStart="6dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Báo cáo tổng hợp"
                                    android:textColor="@color/t1"
                                    android:textStyle="bold"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Xem số liệu toàn hệ thống"
                                    android:textColor="@color/th"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_auth_chevron_right"
                                android:tint="@color/th"
                                android:layout_marginEnd="10dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TÀI KHOẢN"
                    android:textColor="@color/th"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/div"
                    app:strokeWidth="1dp"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/row_change_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="#E6F7EC"
                                android:src="@drawable/ic_auth_password_outline"
                                android:tint="@color/p"
                                android:padding="10dp"
                                android:layout_marginStart="6dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Đổi mật khẩu"
                                android:textColor="@color/t1"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:layout_marginStart="12dp" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_auth_chevron_right"
                                android:tint="@color/th"
                                android:layout_marginEnd="10dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/div"
                            android:layout_marginStart="60dp"
                            android:layout_marginEnd="6dp" />

                        <LinearLayout
                            android:id="@+id/row_logout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="#FEE2E2"
                                android:src="@drawable/ic_auth_logout_outline"
                                android:tint="@color/err"
                                android:padding="10dp"
                                android:layout_marginStart="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đăng xuất"
                                android:textColor="@color/err"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:layout_marginStart="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phiên bản hệ thống v1.0.0\nBuild 2026.03"
                    android:textColor="@color/th"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="14dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>

