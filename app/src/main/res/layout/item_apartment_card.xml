<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card_white"
    android:foreground="?attr/selectableItemBackground">

    <!-- Icon -->
    <LinearLayout
        android:id="@+id/layoutAptIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:background="@drawable/bg_apt_icon"
        android:layout_marginEnd="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_home"
            app:tint="@color/white"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

    </LinearLayout>

    <!-- Name + info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textAptName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bricolage_grotesque"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:text="Chung Cư Xanh ABC" />

        <TextView
            android:id="@+id/textAptInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/dm_sans"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:text="Block A · Phòng 302" />

    </LinearLayout>

    <!-- Status chip -->
    <TextView
        android:id="@+id/chipStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:fontFamily="@font/bricolage_grotesque"
        android:textSize="10sp"
        android:textStyle="bold"
        android:text="Active" />

</LinearLayout>