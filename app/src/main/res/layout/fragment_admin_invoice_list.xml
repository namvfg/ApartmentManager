<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF8F1"> <View
    android:id="@+id/headerBg"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="#2E6F40"
    app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="56dp"
        android:text="Hóa đơn"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Tháng 3/2026"
        android:textColor="#A5C6B1"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

    <TextView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/shape_circle_avatar"
        android:gravity="center"
        android:text="NM"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="140dp"
        android:background="@drawable/bg_white_top_rounded"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <HorizontalScrollView
            android:id="@+id/scrollViewTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="16dp"
            android:paddingVertical="20dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabDraft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Draft (0)"
                    android:background="@drawable/shape_tab_active"
                    android:textColor="#92400E"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"/>

                <TextView
                    android:id="@+id/tabConfirmed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirmed"
                    android:background="@drawable/shape_tab_inactive"
                    android:layout_marginStart="12dp"
                    android:textColor="#6C757D"
                    android:textSize="13sp"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"/>

                <TextView
                    android:id="@+id/tabPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paid"
                    android:background="@drawable/shape_tab_inactive"
                    android:layout_marginStart="12dp"
                    android:textColor="#6C757D"
                    android:textSize="13sp"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"/>

                <TextView
                    android:id="@+id/tabOverdue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overdue"
                    android:background="@drawable/shape_tab_inactive"
                    android:layout_marginStart="12dp"
                    android:textColor="#6C757D"
                    android:textSize="13sp"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:id="@+id/viewDivider"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/shape_tab_inactive"
            android:backgroundTint="#D1D5DB"
            app:layout_constraintTop_toBottomOf="@id/scrollViewTabs" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvInvoices"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            tools:listitem="@layout/item_user_invoice"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/viewDivider" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>