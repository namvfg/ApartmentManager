<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF9">

    <LinearLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/shape_rounded_input"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#1A1A1A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Thống kê"
            android:textColor="#1F3325"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="40dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnFilterMonth"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:background="@drawable/shape_tab_active" android:backgroundTint="#E6F4EA" android:paddingVertical="10dp" android:text="Tháng 3" android:textColor="#2E6F40" android:textSize="13sp" android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnFilterQuarter"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:gravity="center" android:background="@drawable/shape_tab_inactive" android:paddingVertical="10dp" android:text="Quý 1" android:textColor="#6C757D" android:textSize="13sp" />

                <TextView
                    android:id="@+id/btnFilterYear"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:gravity="center" android:background="@drawable/shape_tab_inactive" android:paddingVertical="10dp" android:text="2026" android:textColor="#6C757D" android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#F0FDF4"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#BBF7D0"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvSummaryPeriod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng đã đóng"
                        android:textColor="#8BAF95"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvUserTotalPaid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:text="0 đ"
                        android:textColor="#2E6F40"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUserPaidCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 hóa đơn"
                        android:textColor="#8BAF95"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvChartTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Chi tiêu gần nhất"
                android:textColor="#1F3325"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartUserExpenses"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_margin="16dp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvBreakdownTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Phân bổ"
                android:textColor="#1F3325"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tiền thuê" android:textColor="#6C757D" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvRentFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 đ" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Điện" android:textColor="#6C757D" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvElectricFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 đ" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Nước" android:textColor="#6C757D" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvWaterFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 đ" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dịch vụ khác" android:textColor="#6C757D" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvOtherFee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 đ" android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>