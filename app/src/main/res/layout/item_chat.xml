<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:background="?attr/selectableItemBackground">

    <!-- Avatar + online dot -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/textAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:fontFamily="@font/bricolage_grotesque"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_avatar_chat" />

        <!-- Online indicator -->
        <View
            android:id="@+id/onlineIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_online_dot"
            android:layout_gravity="bottom|end"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Name + last message -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/bricolage_grotesque"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:text="Nguyễn Văn A" />

            <TextView
                android:id="@+id/textTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:text="09:34" />

        </LinearLayout>

        <TextView
            android:id="@+id/textLastMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Cảm ơn bạn nhiều!" />

    </LinearLayout>

    <!-- Unread badge -->
    <TextView
        android:id="@+id/badgeUnread"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:fontFamily="@font/bricolage_grotesque"
        android:textSize="9sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/bg_badge_red"
        android:visibility="gone"
        android:text="2" />

</LinearLayout>