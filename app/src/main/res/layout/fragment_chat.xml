<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Back button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_back_button"
            android:padding="8dp"
            android:layout_marginEnd="10dp" />

        <!-- Avatar -->
        <TextView
            android:id="@+id/textChatAvatar"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:fontFamily="@font/bricolage_grotesque"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_avatar_chat"
            android:layout_marginEnd="10dp"
            android:text="NV" />

        <!-- Name + room -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textChatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bricolage_grotesque"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_on_dark"
                android:text="Nguyễn Văn An" />

            <TextView
                android:id="@+id/textChatRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans"
                android:textSize="10sp"
                android:textColor="@color/text_on_dark_sub"
                android:text="Phòng A-101 · Block A" />

        </LinearLayout>

    </LinearLayout>

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background"
        android:padding="12dp"
        android:clipToPadding="false" />

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@color/white"
        android:elevation="4dp">

        <EditText
            android:id="@+id/editMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_chat"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:fontFamily="@font/dm_sans"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:hint="Nhập tin nhắn..."
            android:textColorHint="@color/text_hint"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:layout_marginEnd="8dp" />

        <!-- Send button -->
        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_send_button"
            android:padding="10dp" />

    </LinearLayout>

</LinearLayout>