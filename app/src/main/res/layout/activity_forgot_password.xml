<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_input"
        android:clickable="true"
        android:contentDescription="Back"
        android:focusable="true"
        android:padding="8dp"
        android:elevation="10dp"
        android:src="@drawable/ic_auth_back_chevron"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back"
        app:tint="@color/p" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="100dp"
                android:padding="26dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/tv_forgot_icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:padding="18dp"
                    android:src="@drawable/ic_auth_forgot_lock"
                    android:layout_marginBottom="16dp"
                    app:tint="@color/pd" />

                <TextView
                    android:id="@+id/tv_forgot_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quên mật khẩu"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_forgot_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập email để nhận mã đặt lại mật khẩu"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="330dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/div"
                app:strokeWidth="1.5dp"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="@color/t1"
                        android:paddingLeft="20dp"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_auth_field"
                        android:orientation="horizontal"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:layout_marginBottom="6dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_auth_email_outline"
                            app:tint="@color/pl" />

                        <EditText
                            android:id="@+id/et_email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="Nhập địa chỉ email"
                            android:textColor="@color/t1"
                            android:textSize="14sp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="textEmailAddress" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_send_otp"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:text="Gửi mã OTP"
                        android:textSize="16sp"
                        android:backgroundTint="@color/p"
                        android:textColor="@color/white" />

                    <Button
                        android:id="@+id/btn_back_login"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginRight="20dp"
                        android:text="Quay lại đăng nhập"
                        android:textSize="15sp"
                        android:backgroundTint="@color/white"
                        android:textColor="@color/p"
                        android:background="@drawable/bg_input" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

