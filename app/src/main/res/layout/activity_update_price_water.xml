<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER CÓ NÚT BACK -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="15dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:padding="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cập nhật giá nước"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1B4332"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- Giá hiện tại -->
        <TextView
            android:id="@+id/tvCurrentPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Giá hiện tại: 3.500đ/m³"
            android:textColor="#7A9E8F"
            android:layout_marginBottom="20dp" />

        <!-- Giá mới -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Giá mới (đ/m³)"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtPrice"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_input_green"
            android:padding="16dp"
            android:hint="Nhập giá mới"
            android:inputType="number" />

        <!-- Ngày áp dụng -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Áp dụng từ ngày"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edtDate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/bg_input_green"
            android:padding="16dp"
            android:focusable="false"
            android:clickable="true"
            android:hint="Chọn ngày" />

        <!-- Checkbox -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card_service"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <CheckBox
                android:id="@+id/cbNextCycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Áp dụng từ chu kỳ tiếp theo"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giá mới áp dụng sau ngày hiệu lực"
                    android:textColor="#777777"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Button -->
        <Button
            android:id="@+id/btnUpdate"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Cập nhật giá nước"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button"
            android:backgroundTint="@null"
            android:layout_marginTop="30dp"/>

    </LinearLayout>
</ScrollView>