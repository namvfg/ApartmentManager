<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── HEADER GRADIENT ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="vertical">

        <!-- Title row + Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dm_sans"
                    android:text="@string/a01_management_board_title"
                    android:textSize="12sp"
                    android:textColor="@color/text_on_dark_sub"
                    android:letterSpacing="0.03" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:text="@string/a01_apartment_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_dark" />

            </LinearLayout>

            <!-- Avatar -->
            <TextView
                android:id="@+id/avatarAdmin"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:fontFamily="@font/bricolage_grotesque"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:background="@drawable/bg_avatar_circle"
                android:text="NM" />

        </LinearLayout>

        <!-- 3 stat cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Tổng phòng -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="8dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/textTotalUnits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_pale"
                    android:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="9sp"
                    android:textColor="@color/text_on_dark_sub"
                    android:text="Tổng phòng" />

            </LinearLayout>

            <!-- Đang có người -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="8dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/textOccupiedUnits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_dark"
                    android:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="9sp"
                    android:textColor="@color/text_on_dark_sub"
                    android:text="Đang có người" />

            </LinearLayout>

            <!-- HĐ sắp hết -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="8dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/textExpiringContracts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bricolage_grotesque"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FCD34D"
                    android:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="9sp"
                    android:textColor="@color/text_on_dark_sub"
                    android:text="HĐ sắp hết" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── CONTENT ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bricolage_grotesque"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:text="Cần xử lý"
                android:layout_marginBottom="8dp" />

            <!-- Alert: hóa đơn chờ xác nhận (vàng) -->
            <LinearLayout
                android:id="@+id/alertPendingInvoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_alert_yellow"
                android:padding="10dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:background="@drawable/bg_alert_icon_yellow"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_invoice"
                        app:tint="#D97706" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textPendingInvoicesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#92400E"
                        android:text="4 hóa đơn chờ xác nhận" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="10sp"
                        android:textColor="#B45309"
                        android:text="Chu kỳ tháng 3/2026" />

                </LinearLayout>

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#D97706" />

            </LinearLayout>

            <!-- Alert: hóa đơn quá hạn (đỏ) -->
            <LinearLayout
                android:id="@+id/alertOverdueInvoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_alert_red"
                android:padding="10dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:background="@drawable/bg_alert_icon_red"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_warning"
                        app:tint="#EF4444" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textOverdueCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bricolage_grotesque"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#991B1B"
                        android:text="2 hóa đơn quá hạn" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="10sp"
                        android:textColor="#B91C1C"
                        android:text="Đang chờ xử lý" />

                </LinearLayout>

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#EF4444" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>